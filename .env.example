# API base URL — used by the React app at build time (Vite bakes this in)
# For local dev (npm run dev):  http://localhost:4000
# For Docker:                   override via APP_PORT / API_PORT below
VITE_API_URL=http://localhost:4000

# Docker Compose port overrides (optional — defaults shown)
APP_PORT=3000
API_PORT=4000
